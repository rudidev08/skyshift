# Optional audio tooling config only.
# Used by scripts in dev/audio/ and the workflow documented in AUDIO.md.
# Normal game dev, tests, lint, typecheck, and build do not need a .env file.
#
# Audio TTS models (used by audio pipeline scripts in dev/audio/)
AUDIO_BASE_MODEL=mlx-community/Qwen3-TTS-12Hz-1.7B-Base-bf16
AUDIO_VOICE_DESIGN_MODEL=mlx-community/Qwen3-TTS-12Hz-1.7B-VoiceDesign-bf16

# TTS API endpoint (for HTTP-based voice sample/test scripts)
AUDIO_TTS_API=http://localhost:8000/v1/audio/speech

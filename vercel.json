{
  "trailingSlash": false,
  "rewrites": [
    { "source": "/api/telemetry.js", "destination": "https://va.vercel-scripts.com/v1/script.js" },
    { "source": "/start/:preset", "destination": "/universe.html" },
    { "source": "/universe", "destination": "/universe.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
